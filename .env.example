# Bluesky handle (required for all commands except init/status)
BLUESKY_HANDLE=your-handle.bsky.social

# No app password needed — Charcoal uses the public AT Protocol API.
# An app password will be required in the future for blocking/muting features.
# BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional: Public AT Protocol API endpoint (defaults to https://public.api.bsky.app)
# PUBLIC_API_URL=https://public.api.bsky.app

# Optional: Constellation backlink index URL (defaults to https://constellation.microcosm.blue)
# CONSTELLATION_URL=https://constellation.microcosm.blue

# Toxicity scorer backend: "onnx" (default) or "perspective"
# ONNX runs locally with no API key needed — just run `charcoal download-model` first.
# CHARCOAL_SCORER=onnx

# Optional: directory for ONNX model files (defaults to ~/.local/share/charcoal/models/)
# CHARCOAL_MODEL_DIR=/path/to/models

# Google Perspective API key (only needed if CHARCOAL_SCORER=perspective)
# PERSPECTIVE_API_KEY=AIza...

# Optional: path to the SQLite database (defaults to ./charcoal.db)
# CHARCOAL_DB_PATH=./charcoal.db

# Optional: PostgreSQL connection URL (uses Postgres backend when set)
# Requires building with: cargo build --features postgres
# DATABASE_URL=postgres://charcoal:password@localhost/charcoal

# Optional: log level (defaults to info)
# RUST_LOG=charcoal=info

# ── Web dashboard (charcoal serve) ──────────────────────────────────
# Required when running `charcoal serve` (--features web)
#
# Your Bluesky DID — only this account can sign in.
# Find it at: https://bsky.app → Settings → Account (starts with did:plc:)
# CHARCOAL_ALLOWED_DID=did:plc:xxxxxxxxxxxxxxxxxxxx
#
# Public URL of your OAuth client metadata document.
# For dev: register at cimd-service.fly.dev (see docs/plans/2026-03-08-atproto-oauth-impl.md)
# For production: https://{YOUR_DOMAIN}/oauth-client-metadata.json
# CHARCOAL_OAUTH_CLIENT_ID=https://your-domain.example.com/oauth-client-metadata.json
#
# HMAC signing key for session cookies (min 32 chars). Generate with: openssl rand -hex 32
# CHARCOAL_SESSION_SECRET=32-plus-byte-random-hex-string
#
# CHARCOAL_PORT=3000
# CHARCOAL_BIND=0.0.0.0

# ── S3-compatible backup storage (chainlink + deciduous DBs) ────────
# Used by scripts/install-hooks.sh (pre-commit auto-backup) and
# scripts/restore-dbs.sh (disaster recovery).
#
# Provider-agnostic — works with any S3-compatible storage:
#   Cloudflare R2:  https://<account-id>.r2.cloudflarestorage.com
#   Backblaze B2:   https://s3.<region>.backblazeb2.com
#   AWS S3:         https://s3.<region>.amazonaws.com
#
# ⚠️  UNTIL ALL FOUR OF THESE ARE SET, NO BACKUP RUNS. The pre-commit hook
#     checks BACKUP_S3_BUCKET + ACCESS_KEY_ID + SECRET_ACCESS_KEY + ENDPOINT
#     and silently skips the upload if any is empty ("Backup not configured").
#     The chainlink issue DB has been lost to this before — see .gitignore.
#
# To set up Cloudflare R2:
#   1. Cloudflare dashboard → R2 → Create bucket (e.g. charcoal-backups)
#   2. R2 → Manage R2 API Tokens → Create API token (Object Read & Write)
#   3. Copy Account ID, Access Key ID, Secret Access Key into the vars below
#
# BACKUP_S3_BUCKET=charcoal-backups
# BACKUP_S3_ACCESS_KEY_ID=...
# BACKUP_S3_SECRET_ACCESS_KEY=...
# BACKUP_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# BACKUP_S3_REGION=auto

# ── Zentropi CoPE API (binary toxicity classification) ──────────────────────
# When ZENTROPI_API_KEY + ZENTROPI_LABELER_ID are set, Charcoal runs a two-stage
# scoring pipeline: ONNX acts as a clean-pass filter (< 0.10 = cleared) and
# anything above the threshold is sent to Zentropi for a binary toxic/safe
# verdict that drives the threat formula's toxicity rate.
#
# Without these set, the pipeline falls back to ONNX-only with a 0.50 binary
# threshold — works, but loses the labeler's ability to distinguish ally use of
# identity terms ("fuck yeah, fat liberation!") from hostile use.
#
# Get an API key + labeler ID at https://zentropi.ai. The labeler must be
# configured with the conversation-scoped policy in refs/labeler_prompt.txt.
# ZENTROPI_LABELER_VERSION_ID is optional — pin it to a specific version when
# you want to lock the policy snapshot for reproducibility.
#
# ZENTROPI_API_KEY=
# ZENTROPI_LABELER_ID=
# ZENTROPI_LABELER_VERSION_ID=
