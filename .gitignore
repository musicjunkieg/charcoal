# Deciduous — local binary DB only; JSON exports in docs/ are tracked
.deciduous/

# Rust build artifacts
/target/

# Environment secrets (but NOT .env.example — that's the template)
/.env

# Local credential files — these contain live API keys and must never be
# committed. Code reads creds from env vars (see .env.example) only.
refs/zentropi_info.txt

# SQLite database files
*.db
*.db-wal
*.db-shm

# Generated reports
/output/

# Database and report backups
/backups/

# Research scratch files
/docs/research/

# Chainlink local state. NOTE: there is NO automatic backup unless the four
# BACKUP_S3_* vars are set in .env (see .env.example) — when they are unset
# the pre-commit hook prints "Backup not configured" and skips the upload,
# a notice that is easy to miss. Target is Cloudflare R2.
# issues.db is per-clone; issues-export.json is the shared recovery source.
.chainlink/issues.db
.chainlink/.cache/
.chainlink/issues-export.json

# Git worktrees (local ephemeral state)
.worktrees/
.claude/worktrees/

# Downloaded ML model artifacts — fetched via `charcoal download-model`,
# never committed (the binary blobs are ~210 MB and derivable from
# upstream Hugging Face releases)
models/

# Python bytecode + pytest cache (e.g. gpu/cope-b-runpod test runs)
__pycache__/
*.pyc
.pytest_cache/

# Superpowers brainstorm session scratch — ephemeral local server state
# (.server.pid/.log, generated HTML mockups). Installed skills live under
# .agents/skills and .claude/skills, which ARE tracked.
.superpowers/
