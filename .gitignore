# ── Environment & secrets ──────────────────────────────────────────
# .env.example is tracked (it documents required vars); every other
# .env* file is ignored — covers .env, .env.local, .env.production,
# .env.staging, .env.*.local, etc.
.env
.env.*
!.env.example

# ── Per-project ignore extensions ──────────────────────────────────
# `.gitignore.local` is the extension point for project-specific ignore
# patterns that don't belong in the template. The template ignores it
# so it never lands in git, and git respects its patterns locally like
# a normal .gitignore. This lets `update-project-from-template` overwrite
# .gitignore freely without clobbering project-only entries. See the
# CLAUDE.md convention block for the migration pattern.
.gitignore.local

# ── macOS ──────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.apdisk

# ── Editors / IDEs ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Rust ───────────────────────────────────────────────────────────
target/
Cargo.lock.bak
**/*.rs.bk

# ── Node / JavaScript / TypeScript ─────────────────────────────────
node_modules/
dist/
build/
.next/
.nuxt/
.svelte-kit/
.vite/
.turbo/
.parcel-cache/
*.tsbuildinfo
.npm/

# ── Python ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Logs ───────────────────────────────────────────────────────────
*.log
logs/

# ── SQLite databases (blanket) ─────────────────────────────────────
# Local state only — authoritative copies of chainlink/deciduous DBs
# live in Tigris backups. Blanket pattern also catches any future
# app-level sqlite files without needing to touch this list.
*.db
*.db-shm
*.db-wal

# ── Claude Code per-clone state ────────────────────────────────────
.claude/settings.local.json

# ── Deciduous local state ──────────────────────────────────────────
# Everything under .deciduous/ is local ephemeral state (the DB is
# covered by *.db above; config/documents are regenerated by deciduous
# itself). .gitkeep is re-included so the directory survives a fresh
# checkout.
.deciduous/*
!.deciduous/.gitkeep

# ── Chainlink local state ──────────────────────────────────────────
# (issues.db is covered by *.db above)
# (issues-export.json is force-added by the pre-commit hook)
.chainlink/.cache/
.chainlink/issues-export.json
